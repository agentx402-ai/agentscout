{
  "name": "@agentscout/cli",
  "version": "0.1.0",
  "description": "AgentScout CLI + `agentscout mcp` MCP server.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentscout": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "tsc --noEmit && vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentscout/client": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "viem": "^2.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsup": "^8.3.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.0"
  }
}
