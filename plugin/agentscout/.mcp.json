{
  "mcpServers": {
    "agentscout": {
      "command": "npx",
      "args": ["-y", "@agentscout/cli", "mcp"],
      "env": {
        "AGENTSCOUT_ENDPOINT": "${user_config.endpoint}",
        "AGENTSCOUT_PRIVATE_KEY": "${user_config.private_key:-}",
        "AGENTSCOUT_ACCOUNT_KEY": "${user_config.account_key:-}",
        "AGENTSCOUT_NETWORK": "${user_config.network:-eip155:8453}",
        "AGENTSCOUT_MAX_SPEND_USD": "${user_config.max_spend_usd:-}",
        "AGENTSCOUT_MAX_SESSION_SPEND_USD": "${user_config.max_session_spend_usd:-}",
        "AGENTSCOUT_MAX_TOLL_USD": "${user_config.max_toll_usd:-}"
      }
    }
  }
}
